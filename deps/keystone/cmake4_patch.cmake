# CMake 4 no longer allows CMP0051 OLD (Keystone 0.9 still sets it).
if(NOT DEFINED KEYSTONE_SOURCE_DIR)
	message(FATAL_ERROR "cmake4_patch.cmake: KEYSTONE_SOURCE_DIR not set")
endif()
foreach(_rel IN ITEMS CMakeLists.txt llvm/CMakeLists.txt)
	set(_path "${KEYSTONE_SOURCE_DIR}/${_rel}")
	if(NOT EXISTS "${_path}")
		continue()
	endif()
	file(READ "${_path}" _c)
	if(_c MATCHES "cmake_policy\\(SET CMP0051 OLD\\)")
		string(REPLACE "cmake_policy(SET CMP0051 OLD)" "cmake_policy(SET CMP0051 NEW)" _c "${_c}")
		file(WRITE "${_path}" "${_c}")
		message(STATUS "Keystone: patched CMP0051 for CMake 4 (${_rel})")
	endif()
endforeach()

# RetDec local development environment (copy to .env and adjust)
# Source before running GUI tests or scripts:  set -a && source .env && set +a  (bash)
# PowerShell: Get-Content .env | ForEach-Object { ... } or use your shell's dotenv helper.

# Headless GUI / CI-style tests (required for retdec-gui-tests without a display)
RETDEC_GUI_HEADLESS=1
QT_QPA_PLATFORM=offscreen

# Optional: override reported version string (packaging / smoke tests)
# RETDEC_VERSION=5.0.0

# Optional: CUDA toolkit paths (Windows — usually auto-detected from CUDA_PATH)
# CUDA_PATH=C:\Program Files\NVIDIA GPU Computing Toolkit\CUDA\v12.6
# CUDA_HOME=${CUDA_PATH}

# Optional: verbose decompiler diagnostics (see docs/README.md)
# RETDEC_HEURISTIC_DIAG=1
# RETDEC_BIN2LLVMIR_DIAG=1

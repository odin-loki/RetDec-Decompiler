# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[*.{md,sh,py,ps1,cpp,h}]
trim_trailing_whitespace = true

[*.md]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.ps1]
indent_style = space
indent_size = 4

[*.{cpp,h}]
indent_style = tab
indent_size = 4

[*.sh]
indent_style = tab

[Makefile]
indent_style = tab

[CMakeLists.txt]
indent_style = space
indent_size = 4

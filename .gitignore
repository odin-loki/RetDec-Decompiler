# ───────────────────────────────────────────────────────────────────────────
# RetDec — Git ignore policy
#
# Rules of thumb:
#   1. Anything generated by a build belongs out of the repo.
#   2. Nothing > 1 MiB is committed. Large support data and ML models are
#      pulled on demand by scripts/fetch-large-files.{ps1,sh}.
#   3. Tooling/editor noise is kept out.
# ───────────────────────────────────────────────────────────────────────────

# ── Build / install / dist trees ──────────────────────────────────────────
/build/
/install/
/dist/

# Release binaries (GitHub Releases only — not committed)
/releases/windows/
/releases/linux/*.tar.gz
/releases/linux/*.AppImage
/releases/linux/*.deb
/Debug/
/Release/

# ── Local-only git history backups ────────────────────────────────────────
/.git_backup/
/.git_backup.old/

# ── Bundled ML models (multi-GB GGUF/SafeTensors) ─────────────────────────
/models/

# ── Large source data files (>1 MiB) — fetched on demand ──────────────────
# RetDec runtime data: type info, ordinals, YARA patterns. These are
# necessary to *run* the decompiler but are downloaded by
# scripts/fetch-large-files.{ps1,sh} so the git tree stays small.
/support/types/windows.json
/support/types/windrivers.json
/support/types/linux.json
/support/yara_patterns/signsrch/signsrch.yara
/support/ordinals/x86/mfc*.ord
/support/yara_patterns/tools/pe/x86/packers.yara

# Generated, very large source (50 k-entry word list for variable naming).
# Auto-fetched alongside the support data.
/src/llvmir2hll/var_name_gen/var_name_gens/word_var_name_gen.cpp

# ── Profiling / debug-driver artifacts ────────────────────────────────────
/tools/procdump/
/_crash_dumps/
/gui-debug-artifacts/
/gui-tests-debug-artifacts/
/test-artifacts/
/cli-smoke-artifacts/
/_profile_run/
/_gui_perf/
/_perf/
/_smoke/
/_v3smoke/
/_full_smoke/
/_full_smoke_gui/

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dev-debug.log

# ── Editor / OS / tooling noise ───────────────────────────────────────────
.idea/
.vscode/
.cursor/
.taskmaster/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini

# ── Misc ──────────────────────────────────────────────────────────────────
node_modules/
.env
__pycache__/
*.pyc
luac.out
